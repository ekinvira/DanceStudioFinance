<Window x:Class="DanceStudioFinance.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DanceStudioFinance.Views"
        mc:Ignorable="d"
        Title="Dance Studio Finance"
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F5F5">
        <Border Background="White"
                CornerRadius="12"
                Padding="30"
                Margin="40">
            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Dance Studio Finance"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="Gelir - Gider Yönetim Paneli"
                           FontSize="16"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <Button x:Name="btnIncome" Content="Gelir Ekle"
                        Height="45"
                        Margin="0,0,0,15"
                        FontSize="16" Click="btnIncome_Click"/>

                <Button x:Name="btnExpense" Content="Gider Ekle"
                        Height="45"
                        Margin="0,0,0,15"
                        FontSize="16" Click="btnExpense_Click"/>

                <Button Content="Raporlar"
                        Height="45"
                        FontSize="16"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>