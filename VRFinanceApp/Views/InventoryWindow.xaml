<Window x:Class="VRFinanceApp.Views.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Envanter Yönetimi"
        Height="860"
        Width="1080"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB">

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<Grid Margin="20">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Başlık -->
			<Border Grid.Row="0"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,20">
				<StackPanel>
					<TextBlock Text="Envanter Yönetimi"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#1F2937"/>
					<TextBlock Text="Ürün ekle, güncelle, sil ve düşük stokları takip et"
                               Margin="0,6,0,0"
                               FontSize="14"
                               Foreground="#6B7280"/>
				</StackPanel>
			</Border>

			<!-- Özet Kartları -->
			<Grid Grid.Row="1" Margin="0,0,0,20">
				<Grid.ColumnDefinitions>
					<ColumnDefinition/>
					<ColumnDefinition/>
				</Grid.ColumnDefinitions>

				<Border Grid.Column="0"
                        Background="#EEF2FF"
                        CornerRadius="16"
                        Padding="18"
                        Margin="0,0,10,0">
					<StackPanel>
						<TextBlock Text="Toplam Stok Değeri"
                                   FontSize="14"
                                   Foreground="#4F46E5"/>
						<TextBlock x:Name="txtTotalInventoryValue"
                                   Text="0 ₺"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#312E81"
                                   Margin="0,8,0,0"/>
					</StackPanel>
				</Border>

				<Border Grid.Column="1"
                        Background="#FEF2F2"
                        CornerRadius="16"
                        Padding="18"
                        Margin="10,0,0,0">
					<StackPanel>
						<TextBlock Text="Düşük Stoklu Ürün Sayısı"
                                   FontSize="14"
                                   Foreground="#DC2626"/>
						<TextBlock x:Name="txtLowStockCount"
                                   Text="0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="#991B1B"
                                   Margin="0,8,0,0"/>
					</StackPanel>
				</Border>
			</Grid>

			<!-- Form -->
			<Border Grid.Row="2"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,20">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>

					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>

					<!-- Ürün Adı -->
					<StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
						<TextBlock Text="Ürün Adı"/>
						<TextBox x:Name="txtItemName" Margin="0,5,0,0"/>
					</StackPanel>

					<!-- Kategori -->
					<StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,15">
						<TextBlock Text="Kategori"/>
						<TextBox x:Name="txtCategory" Margin="0,5,0,0"/>
					</StackPanel>

					<!-- Adet -->
					<StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
						<TextBlock Text="Adet"/>
						<TextBox x:Name="txtQuantity"
                                 Margin="0,5,0,0"
                                 PreviewTextInput="OnlyNumber"/>
					</StackPanel>

					<!-- Birim Fiyat -->
					<StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,15">
						<TextBlock Text="Birim Fiyat"/>
						<TextBox x:Name="txtPrice"
                                 Margin="0,5,0,0"
                                 PreviewTextInput="OnlyNumber"/>
					</StackPanel>

					<!-- Tarih -->
					<StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,15">
						<TextBlock Text="Tarih"/>
						<DatePicker x:Name="dpDate" Margin="0,5,0,0"/>
					</StackPanel>

					<!-- Not -->
					<StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,15">
						<TextBlock Text="Not"/>
						<TextBox x:Name="txtNote"
                                 Margin="0,5,0,0"
                                 Height="70"
                                 TextWrapping="Wrap"/>
					</StackPanel>

					<!-- Uyarı -->
					<Border Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Background="#FFF7ED"
                            CornerRadius="12"
                            Padding="14"
                            Margin="0,0,0,15">
						<StackPanel>
							<TextBlock Text="Düşük Stok Uyarısı"
                                       FontWeight="Bold"
                                       Foreground="#C2410C"/>
							<TextBlock x:Name="txtLowStockWarning"
                                       Text="Düşük stoklu ürün yok."
                                       Margin="0,6,0,0"
                                       Foreground="#9A3412"
                                       TextWrapping="Wrap"/>
						</StackPanel>
					</Border>

					<!-- Butonlar -->
					<StackPanel Grid.Row="4"
                                Grid.ColumnSpan="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center">
						<Button x:Name="btnSave"
                                Content="Kaydet"
                                Width="140"
                                Height="42"
                                Margin="8"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="#2563EB"
                                Foreground="White"
                                BorderThickness="0"
                                Click="btnSave_Click"/>

						<Button x:Name="btnUpdate"
                                Content="Güncelle"
                                Width="140"
                                Height="42"
                                Margin="8"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="#16A34A"
                                Foreground="White"
                                BorderThickness="0"
                                Click="btnUpdate_Click"/>

						<Button x:Name="btnDelete"
                                Content="Sil"
                                Width="140"
                                Height="42"
                                Margin="8"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="#DC2626"
                                Foreground="White"
                                BorderThickness="0"
                                Click="btnDelete_Click"/>

						<Button x:Name="btnClear"
                                Content="Temizle"
                                Width="140"
                                Height="42"
                                Margin="8"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="#6B7280"
                                Foreground="White"
                                BorderThickness="0"
                                Click="btnClear_Click"/>
					</StackPanel>
				</Grid>
			</Border>

			<!-- Liste -->
			<Border Grid.Row="3"
                    Background="White"
                    CornerRadius="16"
                    Padding="20">
				<StackPanel>
					<TextBlock Text="Envanter Listesi"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,0,0,12"/>

					<DataGrid x:Name="dgInventory"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowBackground="White"
                              AlternatingRowBackground="#F8FAFC"
                              BorderThickness="0"
                              MinHeight="280"
                              SelectionChanged="dgInventory_SelectionChanged">
						<DataGrid.Columns>
							<DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
							<DataGridTextColumn Header="Ürün" Binding="{Binding ItemName}" Width="*"/>
							<DataGridTextColumn Header="Kategori" Binding="{Binding Category}" Width="150"/>
							<DataGridTextColumn Header="Adet" Binding="{Binding Quantity}" Width="90"/>
							<DataGridTextColumn Header="Birim Fiyat" Binding="{Binding UnitPrice}" Width="120"/>
							<DataGridTextColumn Header="Toplam Değer" Binding="{Binding TotalValue}" Width="140"/>
							<DataGridTextColumn Header="Tarih" Binding="{Binding PurchaseDate}" Width="120"/>
							<DataGridTextColumn Header="Not" Binding="{Binding Note}" Width="200"/>
						</DataGrid.Columns>
					</DataGrid>
				</StackPanel>
			</Border>
		</Grid>
	</ScrollViewer>
</Window>